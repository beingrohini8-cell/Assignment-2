public class Main {
    public static void main(String[] args) {

        // 1️⃣ String (Immutable)
        String str = "Hello";
        System.out.println("Original String: " + str);

        str.concat(" World");  // This does NOT change original string
        System.out.println("After concat (without storing): " + str);

        str = str.concat(" World");  // Now it creates new object
        System.out.println("After concat (stored): " + str);


        // 2️⃣ StringBuilder (Mutable, Not Thread-Safe)
        StringBuilder sb = new StringBuilder("Hello");
        System.out.println("\nOriginal StringBuilder: " + sb);

        sb.append(" World");  // Modifies same object
        System.out.println("After append: " + sb);


        // 3️⃣ StringBuffer (Mutable, Thread-Safe)
        StringBuffer sbf = new StringBuffer("Hello");
        System.out.println("\nOriginal StringBuffer: " + sbf);

        sbf.append(" World");  // Modifies same object
        System.out.println("After append: " + sbf);
    }
}
